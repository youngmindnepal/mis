generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// schema.prisma - Fix the relations

model User {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  name            String?
  password        String
  phone           String?
  address         String?
  profilePicture  String?
  status          Status     @default(active)
  roleId          Int
  role            Role       @relation(fields: [roleId], references: [id])

  departmentId    Int?
  department      Department?      @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headedDepartments Department[]    @relation("HeadOfDepartment")

  students        Student[]
  faculty          Faculty[]

  enteredResults     Result[]        @relation("EnteredResults")  // Changed from "EnteredByUser"
  verifiedResults    Result[]        @relation("VerifiedResults")  // Changed from "VerifiedByUser"
    
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@index([roleId])
  @@index([email])
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  
  users       User[]
  permissions RolePermission[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  resource    String
  action      String
  category    String?
  roles       RolePermission[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@unique([resource, action])
}

model RolePermission {
  roleId       Int
  permissionId Int
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@id([roleId, permissionId])
}

enum Status {
  active
  inactive
}

model Department {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  code            String           @unique
  description     String?
  status          DepartmentStatus @default(active)
  headOfDepartmentId Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  users           User[]           @relation("DepartmentUsers")
  headOfDepartment User?           @relation("HeadOfDepartment", fields: [headOfDepartmentId], references: [id])
  batches         Batch[]
  courses         Course[]
  classrooms      Classroom[]
  exams           Exam[]
  courseLists      CourseList[]

}

enum DepartmentStatus {
  active
  inactive
  archived
}

model Batch {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  academicYear    String?
  startDate       DateTime?
  endDate         DateTime?
  status          BatchStatus      @default(active)
  departmentId    Int?
  
  department      Department?      @relation(fields: [departmentId], references: [id])
  calendars        AcademicCalendar[]
  students        Student[]
  classrooms      Classroom[]
  exams           Exam[]
  courseLists      CourseList[]
  examConfigs      ExamConfig[]
  routines        Routine[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum BatchStatus {
  active
  inactive
  completed
  archived
}

// Add this to your schema.prisma file

model Student {
  id              Int        @id @default(autoincrement())
  name            String
  email           String?    @unique
  phone           String?
  address         String?
  enrollmentNo    String?    @unique
  rollNo          String?
  dateOfBirth     DateTime?
  gender          String?
  profilePicture  String?
  status          Status     @default(active)
  inactiveDate     DateTime? 
  examRollNumber String?    @unique
   enrollmentDate DateTime?  @default(now())

   // Add these fields if you want them in database
  bloodGroup      String?
  guardianName    String?
  guardianContact String?
  guardianEmail   String?
  emergencyContact String?
  
  userId          Int?       @unique
  user            User?      @relation(fields: [userId], references: [id])

  batchId         Int?
  batch           Batch?     @relation(fields: [batchId], references: [id])
  attendances     Attendance[]
  attendanceSummary AttendanceSummary[]
  classroomEnrollments ClassroomEnrollment[]

  results         Result[]
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@index([batchId])
  @@index([enrollmentNo])
}

model Course {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  code            String           @unique
  credits         Int?
  description     String?
  lecture         Int?
  tutorial        Int?
  practical       Int?
  noncredit       Boolean          @default(false)
  courseType      CourseType       @default(core)
  semester        Semester         @default(semester1)
  syllabus        String?
  departmentId    Int?
  
  department      Department?      @relation(fields: [departmentId], references: [id])
  classrooms      Classroom[]
  courseLists      CourseList[]
  results         Result[]
  routines        Routine[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum CourseType {
  core
  elective
}

enum Semester {
  semester1
  semester2
  semester3
  semester4
  semester5
  semester6
  semester7
  semester8
}


model Faculty {
  id              Int              @id @default(autoincrement())
  name            String
  phone           String?          @unique
  email           String?          @unique
  address         String?
  joinedDate      DateTime         @default(now())
  cv              String?
  designation     String?
  qualification   String?
  specialization  String?
  status          FacultyStatus    @default(active)
  
  userId          Int?             @unique
  user            User?            @relation(fields: [userId], references: [id])
  classrooms      Classroom[]
  sessions        ClassSession[]
  routines        Routine[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum FacultyStatus {
  active
  inactive
  on_leave
  retired
}
model Classroom {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  startDate       DateTime?
  endDate         DateTime?
  capacity        Int?
  courseId        Int?
  facultyId       Int?
  batchId         Int?
  departmentId    Int?
  status          String?           @default("active")
  
  course          Course?          @relation(fields: [courseId], references: [id])
  faculty         Faculty?         @relation(fields: [facultyId], references: [id])
  batch           Batch?           @relation(fields: [batchId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  enrollments     ClassroomEnrollment[]
  sessions        ClassSession[]
  attendanceSummary AttendanceSummary[]
  exams           Exam[]
  results         Result[]
  routines        Routine[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ClassroomEnrollment {
  id              Int              @id @default(autoincrement())
  studentId       Int
  classroomId     Int
  enrolledAt      DateTime         @default(now())
  status          EnrollmentStatus @default(active)
  
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, classroomId])
  @@index([classroomId])
  @@index([studentId])
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

// ============================================
// ATTENDANCE TRACKING
// ============================================

model ClassSession {
  id              Int              @id @default(autoincrement())
  title           String
  date            DateTime         @default(now())
  startTime       DateTime?
  endTime         DateTime?
  syllabusCovered String?
  notes           String?
  materialUrl     String?
  sessionType     SessionType      @default(regular)
  
  classroomId     Int
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  facultyId       Int?
  faculty         Faculty?         @relation(fields: [facultyId], references: [id])
  attendances     Attendance[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@unique([classroomId, date, startTime])
  @@index([date])
  @@index([classroomId, date])
  @@index([facultyId])
}

enum SessionType {
  regular
  makeup
  special
  exam
  holiday
}

model Attendance {
  id              Int              @id @default(autoincrement())
  status          AttendanceStatus @default(present)
  checkInTime     DateTime?
  checkOutTime    DateTime?
  remarks         String?
  markedBy        Int?
  markedAt        DateTime         @default(now())
  
  studentId       Int
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSessionId  Int
  classSession    ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, classSessionId])
  @@index([studentId])
  @@index([classSessionId])
  @@index([status])
}

enum AttendanceStatus {
  present
  absent
  late
  excused
  holiday
}

// ============================================
// ATTENDANCE ANALYTICS
// ============================================

model AttendanceSummary {
  id              Int              @id @default(autoincrement())
  studentId       Int
  classroomId     Int
  totalSessions   Int              @default(0)
  presentCount    Int              @default(0)
  absentCount     Int              @default(0)
  lateCount       Int              @default(0)
  excusedCount    Int              @default(0)
  percentage      Float            @default(0)
  lastUpdated     DateTime         @default(now())
  
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, classroomId])
  @@index([studentId])
  @@index([classroomId])
  @@index([percentage])
}

model ExamType{
  id Int @id @default(autoincrement())
  name String @unique
  code String @unique
  description String?
  status ExamTypeStatus @default(active)
  weightage Float?
  isGraded Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exams Exam[]
  results Result[]


}

enum ExamTypeStatus {
  active
  inactive
  archived
}

model Exam{
  id Int @id @default(autoincrement())
  name String
  
  examTypeId      Int
  examType        ExamType         @relation(fields: [examTypeId], references: [id])

  academicYear String?
  semester Semester?
  date DateTime?
  startTime DateTime?
  endTime DateTime?

  status ExamStatus @default(scheduled)

  departmentId Int?
  department Department? @relation(fields: [departmentId], references: [id])

  batchId Int?
  batch Batch? @relation(fields: [batchId], references: [id])

  classroomId Int?
  classroom Classroom? @relation(fields: [classroomId], references: [id])

  results Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ExamStatus {
  scheduled
  ongoing
  completed
  cancelled
  result_published
}

model Result {
  id              Int              @id @default(autoincrement())
  
  studentId       Int
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  classroomId     Int?
  classroom       Classroom?       @relation(fields: [classroomId], references: [id])

  examId          Int?
  exam            Exam?             @relation(fields: [examId], references: [id], onDelete: Cascade)

  examTypeId      Int?
  examType        ExamType?        @relation(fields: [examTypeId], references: [id])

  courseId        Int?
  course          Course?          @relation(fields: [courseId], references: [id])

 examCategory    ExamCategory     @default(regular)
  attempt         Int?             // For supplementary exams (1, 2, 3, etc.)
  semester        Semester?        // The semester this result belongs to
  // Marks
  theoryMarks     Float?
  practicalMarks  Float?
  totalMarks      Float?
  maxMarks        Float?           @default(100)
  passMarks       Float?           @default(40)

  // Grade
  grade           String?
  gradePoint      Float? 
  resultStatus    ResultStatus     @default(pending)

  // Additional Info
  remarks         String?
  isAbsent        Boolean          @default(false)
  isPassed        Boolean?
  examRollNumber  String?
  resultDate DateTime?
  // Audit
  enteredBy       Int?
  enteredByUser   User?            @relation("EnteredResults", fields: [enteredBy], references: [id])  // Matches User model

  verifiedBy      Int?
  verifiedByUser  User?            @relation("VerifiedResults", fields: [verifiedBy], references: [id])  // Matches User model
  verifiedAt      DateTime?
  
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([studentId, courseId, examCategory, attempt], name: "unique_result_per_attempt")
 
  @@index([studentId])
  @@index([examId])
  @@index([classroomId])
  @@index([resultStatus])
  @@index([examCategory])
  @@index([semester])
  @@index([attempt])
}

enum ResultStatus {
  pending
  draft
  verified
  published
  re_evaluation
  final
}

enum ExamCategory {
  regular
  supplementary
}

model CourseList {
  id              Int              @id @default(autoincrement())

  departmentId    Int
  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  batchId         Int
  courseId        Int
  semester        Semester         @default(semester1)
  isActive        Boolean          @default(true)
 
  
  
  batch           Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@unique([batchId, courseId, semester])
  @@index([batchId])
  @@index([courseId])
  @@index([semester])
}

// Add this to your schema.prisma file

model ExamConfig {
  id            Int      @id @default(autoincrement())
  batchId       Int
  semester      Semester
  examCategory  ExamCategory
  resultDate    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batch         Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, semester, examCategory])
  @@index([batchId])
  @@index([semester])
  @@index([examCategory])
}

model AcademicCalendar {
  id            Int      @id @default(autoincrement())
  date          DateTime
  description   String
  eventType     CalendarEventType
  semester      Semester?
  batchId       Int?
  batch         Batch?   @relation(fields: [batchId], references: [id])
  notices       CalendarNotice[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([eventType])
}

enum CalendarEventType {
  semester_start
  semester_end
  holiday
  first_term_start
  first_term_end
  second_term_start
  second_term_end
  exam_preparation
  exam_start
  exam_end
  result_publication
  supplementary_exam
  college_event
  meeting
  other
}

model CalendarNotice {
  id          Int      @id @default(autoincrement())
  calendarId  Int
  calendar    AcademicCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  noticeType  NoticeType
  title       String
  content     String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NoticeType {
  holiday_notice
  exam_notice
  result_notice
  class_start_notice
  general_notice
}

// Add this model to your schema.prisma file

model Routine {
  id            Int            @id @default(autoincrement())
  
  // Core schedule
  day           Int            // 0=Sunday, 1=Monday, ... 5=Friday
  timeSlot      Int            // Start slot ID (0-13)
  timeSlotEnd   Int?           // End slot ID for merged/merged routines
  
  // Content
  subject       String?        // Subject or description
  
  // Relations
  facultyId     Int?
  faculty       Faculty?        @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  
  batchId       Int?
  batch         Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  classroomId   Int?
  classroom     Classroom?     @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  
  courseId      Int?
  course        Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  // Room info
  roomNumber    String?        // Manual room number input
  
  // Status
  status        RoutineStatus  @default(active)
  
  // Notes
  notes         String?
  
  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@index([day, timeSlot])
  @@index([facultyId])
  @@index([batchId])
  @@index([classroomId])
  @@index([day, facultyId])
}

enum RoutineStatus {
  active
  cancelled
  makeup
  break
}